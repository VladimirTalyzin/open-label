[Unit]
Description=OpenLabel Service
After=network.target

[Service]
User=morfo
Group=morfo
WorkingDirectory=/open-label/server
ExecStart=/open-label/server/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=5
Environment=PATH=/open-label/server/.venv/bin:/usr/local/bin:/usr/bin

[Install]
WantedBy=multi-user.target
